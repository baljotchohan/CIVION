# ─── Gemini API ──────────────────────────────────────────
# Server-side key (private, no NEXT_PUBLIC prefix)
GEMINI_API_KEY=your_gemini_api_key_here
# Client-side key (if needed for direct browser calls)
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# ─── Firebase Admin Credentials (Backend DB) ─────────────
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
# Important: ensure the key is all on one line with \n separating lines
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── JWT Authentication ───────────────────────────────────
# Must be at least 32 characters long
JWT_SECRET=change_me_to_a_long_random_secret_string_32chars
JWT_EXPIRATION=7d

# ─── App Config ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
