# ═══════════════════════════════════════════════
# CIVION v2 - Configuration
# ═══════════════════════════════════════════════

# LLM Providers (at least one recommended)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Default LLM provider: openai | anthropic | google | mock
LLM_PROVIDER=mock

# GitHub API (optional, increases rate limits)
GITHUB_TOKEN=

# News API (optional)
NEWS_API_KEY=

# CoinGecko API (optional, free tier works)
COINGECKO_API_KEY=

# Server Configuration
CIVION_HOST=0.0.0.0
CIVION_PORT=8000
CIVION_DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./civion.db

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Autonomous Mode
AUTONOMOUS_ENABLED=false
AUTONOMOUS_INTERVAL_MINUTES=30

# Network
NETWORK_ENABLED=false
NETWORK_NAME=civion-global
